From c4989878c3ff8e6832264d56a724a851f1a89be6 Mon Sep 17 00:00:00 2001
From: cxw <1739990676@qq.com>
Date: Mon, 19 Jan 2026 09:03:25 +0800
Subject: [PATCH 21/25] add wifi node dtsi for hd-rk3506g-evm

---
 arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi b/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi
index 33f9d3ef1e9b..07a0c1cd9370 100644
--- a/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi
+++ b/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi
@@ -116,6 +116,17 @@ vdd_arm: vdd-arm {
 		regulator-settling-time-up-us = <250>;
 		pwm-supply = <&vcc_sys>;
 	};
+	
+	wireless-bluetooth {
+		compatible = "bluetooth-platdata";
+		status = "okay";
+	};
+
+	wireless-wlan {
+		compatible = "wlan-platdata";
+		rockchip,grf = <&grf>;
+		status = "disabled";
+	};
 };
 
 &fspi {
