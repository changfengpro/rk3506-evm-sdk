---
 arch/arm/boot/dts/rk3506-amp.dtsi                 | 15 ++++++++-------
 .../configs/vanxoak_hd_rk3506g_evm_sd_defconfig   |  5 +++++
 2 files changed, 13 insertions(+), 7 deletions(-)

diff --git a/arch/arm/boot/dts/rk3506-amp.dtsi b/arch/arm/boot/dts/rk3506-amp.dtsi
index 2604238cacd5..2ced30177e7a 100644
--- a/arch/arm/boot/dts/rk3506-amp.dtsi
+++ b/arch/arm/boot/dts/rk3506-amp.dtsi
@@ -18,10 +18,6 @@ rockchip_amp: rockchip-amp {
 		pinctrl-0 = <&rm_io15_uart3_rx &rm_io14_uart3_tx>;
 
 		amp-cpu-aff-maskbits = /bits/ 64 <0x0 0x1 0x1 0x2 0x2 0x4>;
-		amp-irqs = /bits/ 64 <
-
-			/* MAILBOX */
-			GIC_AMP_IRQ_CFG_ROUTE(176, 0xd0, CPU_GET_AFFINITY(0, 2))>;
 
 		status = "okay";
 	};
@@ -29,11 +25,11 @@ rockchip_amp: rockchip-amp {
 	rpmsg: rpmsg@3c00000 {
 		compatible = "rockchip,rpmsg";
 		mbox-names = "rpmsg-rx", "rpmsg-tx";
-		mboxes = <&mailbox0 0 &mailbox2 0>;
+		mboxes = <&mailbox0 0 &mailbox3 0>;
 		rockchip,vdev-nums = <1>;
 		/* CPU3: link-id 0x03; */
 		rockchip,link-id = <0x03>;
-//		reg = <0x3c00000 0x20000>;
+		reg = <0x3c00000 0x200000>;
 		memory-region = <&rpmsg_reserved>, <&rpmsg_dma_reserved>;
 
 		status = "okay";
@@ -49,7 +45,12 @@ &mailbox0 {
 	status = "okay";
 };
 
-&mailbox2 {
+//&mailbox2 {
+//	rockchip,txpoll-period-ms = <1>;
+//	status = "okay";
+//};
+
+&mailbox3 {
 	rockchip,txpoll-period-ms = <1>;
 	status = "okay";
 };
diff --git a/arch/arm/configs/vanxoak_hd_rk3506g_evm_sd_defconfig b/arch/arm/configs/vanxoak_hd_rk3506g_evm_sd_defconfig
index 51a40a19fb4e..5c4ce6de2aaa 100644
--- a/arch/arm/configs/vanxoak_hd_rk3506g_evm_sd_defconfig
+++ b/arch/arm/configs/vanxoak_hd_rk3506g_evm_sd_defconfig
@@ -321,15 +321,20 @@ CONFIG_STAGING=y
 CONFIG_ROCKCHIP_CLK_OUT=y
 # CONFIG_ROCKCHIP_CLK_PVTM is not set
 # CONFIG_ARM_ARCH_TIMER_EVTSTREAM is not set
+CONFIG_MAILBOX=y
+CONFIG_ROCKCHIP_MBOX=y
 # CONFIG_IOMMU_SUPPORT is not set
 CONFIG_REMOTEPROC=y
 CONFIG_REMOTEPROC_CDEV=y
 CONFIG_RPMSG_CHAR=y
 CONFIG_RPMSG_CTRL=y
+CONFIG_RPMSG_QCOM_GLINK_RPM=y
+CONFIG_RPMSG_ROCKCHIP_MBOX=y
 CONFIG_RPMSG_ROCKCHIP_SOFTIRQ=y
 CONFIG_RPMSG_ROCKCHIP_TEST=y
 CONFIG_RPMSG_VIRTIO=y
 CONFIG_CPU_RK3506=y
+CONFIG_ROCKCHIP_AMP=y
 CONFIG_ROCKCHIP_CPUINFO=y
 CONFIG_ROCKCHIP_OPP=y
 CONFIG_ROCKCHIP_SUSPEND_MODE=y
-- 
