From 3dbf54e31380852607545594b9d46b2720b0f021 Mon Sep 17 00:00:00 2001
From: cxw <1739990676@qq.com>
Date: Wed, 5 Nov 2025 08:47:17 +0800
Subject: [PATCH 10/25] change sd det pin

---
 arch/arm/boot/dts/rk3506-evm-v10.dtsi | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/arch/arm/boot/dts/rk3506-evm-v10.dtsi b/arch/arm/boot/dts/rk3506-evm-v10.dtsi
index f636ac97dd7f..b56814b4bb77 100644
--- a/arch/arm/boot/dts/rk3506-evm-v10.dtsi
+++ b/arch/arm/boot/dts/rk3506-evm-v10.dtsi
@@ -133,7 +133,7 @@ &mmc {
     max-frequency = <150000000>;
 	supports-sd;
 	bus-width = <4>;
-	cd-gpios = <&gpio0 RK_PB0 GPIO_ACTIVE_LOW>;
+	cd-gpios = <&gpio3 RK_PA6 GPIO_ACTIVE_LOW>;
 	//cap-mmc-highspeed;
 	cap-sd-highspeed;
 	disable-wp;
@@ -145,6 +145,14 @@ &mmc {
 	status = "okay";
 };
 
+&pinctrl {
+	mmc{
+		cd_gpio: cd_gpio {
+			rockchip,pins = <3 RK_PA6 RK_FUNC_GPIO &pcfg_pull_up>;
+		};
+	};
+};
+
 &cma {
 	size = <0x1600000>;
 };
-- 
