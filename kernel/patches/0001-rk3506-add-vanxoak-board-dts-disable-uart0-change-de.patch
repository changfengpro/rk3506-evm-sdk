Subject: [PATCH] =?UTF-8?q?rk3506:=20add=20vanxoak=20board=20dts,=20disabl?=
 =?UTF-8?q?e=20uart0=EF=BC=88change=20debug=20uart=20to=20uart1=EF=BC=89?=
 =?UTF-8?q?=20=20and=20reserve=20pins=20for=20M0=20SWD?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

---
 arch/arm/boot/dts/rk3506-amp.dtsi             | 44 ++++++-------
 .../boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi    |  6 +-
 .../boot/dts/vanxoak-hd-rk3506g-evm-sd-v1.dts | 30 ++++++++-
 .../vanxoak_hd_rk3506g_evm_sd_defconfig       | 62 +++++++++++++------
 4 files changed, 94 insertions(+), 48 deletions(-)

diff --git a/arch/arm/boot/dts/rk3506-amp.dtsi b/arch/arm/boot/dts/rk3506-amp.dtsi
index 00ba83dd38e9..2604238cacd5 100644
--- a/arch/arm/boot/dts/rk3506-amp.dtsi
+++ b/arch/arm/boot/dts/rk3506-amp.dtsi
@@ -8,29 +8,18 @@
 #define CPU_GET_AFFINITY(cluster, cpu)		(cpu)
 
 / {
-	cpus {
-		/delete-node/ cpu@f02;
-	};
-
 	rockchip_amp: rockchip-amp {
 		compatible = "rockchip,amp";
 		clocks = <&cru HCLK_M0>, <&cru STCLK_M0>,
-			<&cru SCLK_UART4>, <&cru PCLK_UART4>,
+			<&cru SCLK_UART3>, <&cru PCLK_UART3>,
 			<&cru PCLK_TIMER>, <&cru CLK_TIMER0_CH5>;
 
 		pinctrl-names = "default";
-		pinctrl-0 = <&rm_io27_uart4_tx>, <&rm_io28_uart4_rx>;
+		pinctrl-0 = <&rm_io15_uart3_rx &rm_io14_uart3_tx>;
 
 		amp-cpu-aff-maskbits = /bits/ 64 <0x0 0x1 0x1 0x2 0x2 0x4>;
 		amp-irqs = /bits/ 64 <
-			/* GPIO EXT */
-			GIC_AMP_IRQ_CFG_ROUTE(35, 0xd0, CPU_GET_AFFINITY(0, 2))
-			GIC_AMP_IRQ_CFG_ROUTE(39, 0xd0, CPU_GET_AFFINITY(0, 2))
-			GIC_AMP_IRQ_CFG_ROUTE(43, 0xd0, CPU_GET_AFFINITY(0, 2))
-			GIC_AMP_IRQ_CFG_ROUTE(47, 0xd0, CPU_GET_AFFINITY(0, 2))
-			GIC_AMP_IRQ_CFG_ROUTE(51, 0xd0, CPU_GET_AFFINITY(0, 2))
-			/* UART4 */
-			GIC_AMP_IRQ_CFG_ROUTE(70, 0xd0, CPU_GET_AFFINITY(0, 2))
+
 			/* MAILBOX */
 			GIC_AMP_IRQ_CFG_ROUTE(176, 0xd0, CPU_GET_AFFINITY(0, 2))>;
 
@@ -42,10 +31,10 @@ rpmsg: rpmsg@3c00000 {
 		mbox-names = "rpmsg-rx", "rpmsg-tx";
 		mboxes = <&mailbox0 0 &mailbox2 0>;
 		rockchip,vdev-nums = <1>;
-		/* CPU2: link-id 0x02; */
-		rockchip,link-id = <0x02>;
-		reg = <0x3c00000 0x20000>;
-		memory-region = <&rpmsg_dma_reserved>;
+		/* CPU3: link-id 0x03; */
+		rockchip,link-id = <0x03>;
+//		reg = <0x3c00000 0x20000>;
+		memory-region = <&rpmsg_reserved>, <&rpmsg_dma_reserved>;
 
 		status = "okay";
 	};
@@ -73,19 +62,26 @@ amp_shmem_reserved: amp-shmem@3b00000 {
 	};
 
 	rpmsg_reserved: rpmsg@3c00000 {
-		reg = <0x03c00000 0x100000>;
+		reg = <0x03c00000 0x200000>;
 		no-map;
 	};
 
 	rpmsg_dma_reserved: rpmsg-dma@3d00000 {
 		compatible = "shared-dma-pool";
-		reg = <0x03d00000 0x100000>;
+		reg = <0x03e00000 0x100000>;
 		no-map;
 	};
 
 	/* mcu address */
-	mcu_reserved: mcu@fff80000 {
-		reg = <0xfff80000 0xc000>;
-		no-map;
-	};
+//	mcu_reserved: mcu@fff80000 {
+//		reg = <0xfff80000 0xc000>;
+//		no-map;
+//	};
+
+	  /* mcu address */
+	  mcu_reserved: mcu@3a00000 {
+	    reg = <0x03a00000 0x100000>;
+	    no-map;
+	  };
+
 };
diff --git a/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi b/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi
index 07a0c1cd9370..d23d2bc3bda5 100644
--- a/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi
+++ b/arch/arm/boot/dts/vanxoak-hd-rk3506-evm-v1.dtsi
@@ -13,7 +13,7 @@ / {
 
 	chosen {
 		//bootargs = "earlycon=uart8250,mmio32,0xff0a0000 console=ttyFIQ0 ubi.mtd=5 ubi.block=0,rootfs root=/dev/ubiblock0_0 rootfstype=squashfs rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1 storagemedia=mtd androidboot.storagemedia=mtd androidboot.mode=normal";
-		bootargs = "earlycon=uart8250,mmio32,0xff0a0000 console=ttyFIQ0 ubi.mtd=5 root=ubi0:rootfs rw rootfstype=ubifs rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1";
+		bootargs = "earlycon=uart8250,mmio32,0xff0a0000 console=ttyFIQ0 ubi.mtd=5 root=ubi0:rootfs rw rootfstype=ubifs rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1 clk_ignore_unused";
 	};
 
 	backlight: backlight {
@@ -59,7 +59,7 @@ backlight: backlight {
 	
 	fiq_debugger: fiq-debugger {
 		compatible = "rockchip,fiq-debugger";
-		rockchip,serial-id = <0>;
+		rockchip,serial-id = <0>;	
 		rockchip,wake-irq = <0>;
 		rockchip,irq-mode-enable = <1>;
 		rockchip,baudrate = <115200>;	/* Only 115200 and 1500000 */
@@ -309,4 +309,4 @@ &usb20_otg0 {
 &usb20_otg1 {
 	dr_mode = "host";
 	status = "okay";
-};
\ No newline at end of file
+};
diff --git a/arch/arm/boot/dts/vanxoak-hd-rk3506g-evm-sd-v1.dts b/arch/arm/boot/dts/vanxoak-hd-rk3506g-evm-sd-v1.dts
index cc1f6b1cd70a..18d3e636134e 100755
--- a/arch/arm/boot/dts/vanxoak-hd-rk3506g-evm-sd-v1.dts
+++ b/arch/arm/boot/dts/vanxoak-hd-rk3506g-evm-sd-v1.dts
@@ -8,6 +8,7 @@
 #include "rk3506.dtsi"
 #include "vanxoak-hd-rk3506-evm-v1.dtsi"
 #include "vanxoak-hd-rk3506-evm-mipi-480x800.dtsi"
+#include "rk3506-amp.dtsi"
 
 / {
 	model = "Vanxoak HD-RK3506-EVM V10 Board";
@@ -37,8 +38,15 @@ drm_logo: drm-logo@400000 {
 	};
 
 	chosen {
-		bootargs = "earlycon=uart8250,mmio32,0xff0a0000 console=ttyFIQ0 storagemedia=sd root=/dev/mmcblk0p5 rootfstype=ext4 rw rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1";
+		bootargs = "earlycon=uart8250,mmio32,0xff0b0000 console=ttyS1,115200n8 storagemedia=sd root=/dev/mmcblk0p6 rootfstype=ext4 rw rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1 clk_ignore_unused";
 	};
+	
+	m0_debug {
+		compatible = "rockchip,pins-dummy";
+		pinctrl-names = "default";
+		pinctrl-0 = <&jtagm1_pins>; 
+		status = "okay";
+    };
 };
 
 &fspi {
@@ -54,6 +62,11 @@ &saradc {
 	status = "okay";
 };
 
+&uart0 {
+	
+	status = "disabled";
+};
+
 &uart1 {
 	pinctrl-names = "default";
 	pinctrl-0 = <&rm_io16_uart1_rx &rm_io17_uart1_tx>;
@@ -69,7 +82,7 @@ &uart2 {
 &uart3 {
 	pinctrl-names = "default";
 	pinctrl-0 = <&rm_io15_uart3_rx &rm_io14_uart3_tx>;
-	status = "okay";
+	status = "disabled";
 };
 
 &uart4 {
@@ -78,6 +91,19 @@ &uart4 {
 	status = "disabled";
 };
 
+&can0 {
+	status = "disabled";
+};
+
+&can1 {
+	status = "disabled";
+};
+
+&fiq_debugger {
+	status = "disabled";
+};
+
+
 
 
 
