From 2d97469d60956b219a4d3d37c7633196cb062887 Mon Sep 17 00:00:00 2001
From: whwxakdzyxgs_31425 <zhangzhongyu@vanxoak.com>
Date: Thu, 13 Mar 2025 17:41:25 +0800
Subject: [PATCH 05/25] rk3506-iot-nand TF support 32G

---
 arch/arm/boot/dts/rk3506-iot-v10.dtsi | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/arch/arm/boot/dts/rk3506-iot-v10.dtsi b/arch/arm/boot/dts/rk3506-iot-v10.dtsi
index aebb320600da..643870e7e4db 100644
--- a/arch/arm/boot/dts/rk3506-iot-v10.dtsi
+++ b/arch/arm/boot/dts/rk3506-iot-v10.dtsi
@@ -131,14 +131,13 @@ flash@0 {
 
 &mmc {
     max-frequency = <150000000>;
-	no-sdio;
-	no-mmc;
+	supports-sd;
 	bus-width = <4>;
 	cd-gpios = <&gpio0 RK_PB0 GPIO_ACTIVE_LOW>;
-	cap-mmc-highspeed;
+	//cap-mmc-highspeed;
 	cap-sd-highspeed;
 	disable-wp;
-	sd-uhs-sdr104;
+	//sd-uhs-sdr104;
 	vmmc-supply = <&vcc3v3_stb>;
 	vqmmc-supply = <&vcc3v3_stb>;
 	pinctrl-names = "default";
