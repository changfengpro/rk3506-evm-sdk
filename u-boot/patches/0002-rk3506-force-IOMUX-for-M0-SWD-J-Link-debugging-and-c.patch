From a149eb998f682195a50496c6cef8893b5d6510a5 Mon Sep 17 00:00:00 2001
From: changfengpro <2728019272@qq.com>
Date: Sat, 4 Apr 2026 16:14:00 +0800
Subject: [PATCH 2/2] rk3506: force IOMUX for M0 SWD J-Link debugging and
 change debug uart to uart1

---
 arch/arm/dts/rk3506-evb.dts            |  3 ++
 arch/arm/mach-rockchip/rk3506/rk3506.c | 55 +++++++++++++++++++++++++-
 configs/rk3506_defconfig               |  6 ++-
 3 files changed, 62 insertions(+), 2 deletions(-)

diff --git a/arch/arm/dts/rk3506-evb.dts b/arch/arm/dts/rk3506-evb.dts
index 2e29fd8..8967f98 100644
--- a/arch/arm/dts/rk3506-evb.dts
+++ b/arch/arm/dts/rk3506-evb.dts
@@ -29,3 +29,6 @@
 		};
 	};
 };
+
+
+
diff --git a/arch/arm/mach-rockchip/rk3506/rk3506.c b/arch/arm/mach-rockchip/rk3506/rk3506.c
index 8ef9b58..1383646 100644
--- a/arch/arm/mach-rockchip/rk3506/rk3506.c
+++ b/arch/arm/mach-rockchip/rk3506/rk3506.c
@@ -51,9 +51,43 @@ DECLARE_GLOBAL_DATA_PTR;
 #define CRU_GATE_CON5           0x0814
 #define CRU_SOFTRST_CON5        0x0a14
 
+/* 基地址定义 (参考 TRM Chapter 1.1 Address Mapping) */
+#define IOC_PMU_BASE        0xff950000
+#define GRF_PMU_BASE        0xff910000
+
+/* GPIO0_C 组的 IOMUX 控制寄存器偏移量 (控制 PC0~PC3) */
+#define GPIO0C_IOMUX_SEL_0  0x0010
+
+/* * RMIO 路由控制寄存器：配置具体通道的内部信号映射 
+ * RM_IO0 偏移量是 0x0080，每个通道占 4 字节
+ * RM_IO16 对应物理引脚 GPIO0_PC0，偏移量: 0x0080 + 16 * 4 = 0x00C0
+ * RM_IO17 对应物理引脚 GPIO0_PC1，偏移量: 0x0080 + 17 * 4 = 0x00C4
+ */
+#define RM_IO_16_SEL        0x00C0
+#define RM_IO_17_SEL        0x00C4
+
+
 void board_debug_uart_init(void)
 {
 	/* No need to change uart*/
+	/* * 步骤 1：第一层复用 (IOMUX)
+       * 将物理引脚 GPIO0_PC0(RX) 和 GPIO0_PC1(TX) 切换为 RMIO 模式 (MUX = 7)
+       * PC0 占用 bit[3:0], PC1 占用 bit[7:4]
+       * 写入掩码为 0x00FF (高16位写使能), 值为 0x0077 (低16位)
+       */
+    writel(0x00FF0077, IOC_PMU_BASE + GPIO0C_IOMUX_SEL_0);
+
+      /* * 步骤 2：第二层路由 (RMIO Matrix)
+       * 参考 TRM 19.4 Register Description:
+       * func_sel 7'h1 代表 UART1_TX
+       * func_sel 7'h2 代表 UART1_RX
+       *
+       * 将 rm_io16 通道映射为 UART1_RX (功能号 2)
+       * 将 rm_io17 通道映射为 UART1_TX (功能号 1)
+       * * 寄存器高 16 位为写掩码，设为 0xFFFF 允许修改低 16 位所有配置
+       */
+    writel(0xFFFF0002, GRF_PMU_BASE + RM_IO_16_SEL);
+    writel(0xFFFF0001, GRF_PMU_BASE + RM_IO_17_SEL);
 }
 
 void board_set_iomux(enum if_type if_type, int devnum, int routing)
@@ -171,7 +205,26 @@ int arch_cpu_init(void)
 	 * Set mcu jtag clock un-gate.
 	 * Configure when in use.
 	 */
-	//writel(0x00220000, 0xff960000);
+	// writel(0x00220000, 0xff960000);	// 解除SGRF M0访问锁 
+
+
+	/* 1. 彻底解除 SGRF M0 调试访问锁 (清零Bit 1和5) */
+    writel(0x00220000, 0xff960000); 
+
+    /* 2. 启动 M0 时钟并释放复位 */
+    writel(0x00010001, 0xff960400); 
+
+    /* 3. 内部路由矩阵：将 MCU JTAG 信号强行路由到 M1 分组 */
+    writel(0x00300020, 0xff288000); 
+
+    /* 4. 核心 IOMUX 复用
+     * 地址: 0xff950014 (IOC_PMU_BASE + GPIO0C_IOMUX_SEL_1)
+     * gpio0c7_sel (Bit [15:12]) 写入 4'h2 (JTAG TMS M1)
+     * gpio0c6_sel (Bit [11:8])  写入 4'h2 (JTAG TCK M1)
+     * 写掩码: 0xFF00 (高16位写 0xFF00 使能)
+     * 写入值: 0x2200
+     */
+    writel(0xFF002200, 0xff950014);
 
 	/*
 	 * gpio4Ax is used as MIPI by default.
diff --git a/configs/rk3506_defconfig b/configs/rk3506_defconfig
