 CONFIG_ROCKCHIP_FIT_IMAGE=y
 CONFIG_ROCKCHIP_VENDOR_PARTITION=y
 CONFIG_USING_KERNEL_DTB_V2=y
+# CONFIG_ROCKCHIP_PRELOADER_SERIAL is not set
 CONFIG_ROCKCHIP_FIT_IMAGE_PACK=y
