+            }
+            memset((void *)g_can_last_rx_data, 0, sizeof(g_can_last_rx_data));
+            memcpy((void *)g_can_last_rx_data, rx_msg.data, copyLen);
             CANDispatchRxMessage(pReg, &rx_msg);
         }
     }
 }
 
