diff --git a/common/scripts/mk-rootfs.sh b/common/scripts/mk-rootfs.sh
index 2c45726..26d6d98 100755
--- a/common/scripts/mk-rootfs.sh
+++ b/common/scripts/mk-rootfs.sh
@@ -13,6 +13,9 @@ build_buildroot()
 	message "          Start building buildroot($BUILDROOT_VERSION)"
 	message "=========================================="
 
+	echo "   RK_BUILDROOT_CFG  ($RK_BUILDROOT_CFG)"
+	echo "   IMAGE_DIR  ($IMAGE_DIR)"
+
 	"$RK_SCRIPTS_DIR/mk-buildroot.sh" $RK_BUILDROOT_CFG "$IMAGE_DIR"
 
 	if [ -r "$RK_LOG_DIR/post-rootfs.log" ]; then
diff --git a/common/scripts/post-wifibt.sh b/common/scripts/post-wifibt.sh
index ffb7805..3c76dd4 100755
--- a/common/scripts/post-wifibt.sh
+++ b/common/scripts/post-wifibt.sh
@@ -250,6 +250,13 @@ build_wifibt()
 		$KMAKE M=$RKWIFIBT_DIR/drivers/rtl8852be modules
 	fi
 
+	if [[ "$RK_WIFIBT_MODULES" =~ "AIC8800" ]];then
+		echo "building aic8800 wifi driver"
+		$KMAKE M=$RKWIFIBT_DIR/drivers/aic8800 modules
+		echo "building aic8800 bt driver"
+		$KMAKE M=$RKWIFIBT_DIR/drivers/bluetooth_aic8800_driver modules
+	fi
+
 	if ! [[ "$RK_KERNEL_VERSION_RAW" = "6.1" ]];then
 		echo "building realtek bt drivers"
 		$KMAKE M=$RKWIFIBT_DIR/drivers/bluetooth_uart_driver
@@ -375,6 +382,15 @@ build_wifibt()
 		cp $RKWIFIBT_DIR/drivers/bcmdhd/*.ko $TARGET_DIR/lib/modules/
 	fi
 
+	if [[ "$RK_WIFIBT_MODULES" =~ "AIC8800" ]];then
+		echo "Copy AIC8800 file to rootfs:${TARGET_DIR}"
+		cp -r  $RKWIFIBT_DIR/firmware/aic8800/* \
+			$TARGET_DIR/lib/firmware/
+		cp $RKWIFIBT_DIR/drivers/aic8800/aic_load_fw/*.ko $TARGET_DIR/lib/modules/
+		cp $RKWIFIBT_DIR/drivers/aic8800/aic8800_fdrv/*.ko $TARGET_DIR/lib/modules/
+		cp $RKWIFIBT_DIR/drivers/bluetooth_aic8800_driver/*.ko $TARGET_DIR/lib/modules/
+	fi
+
 	# Install boot services
 	install_sysv_service $RKWIFIBT_DIR/S36wifibt-init.sh S
 	install_busybox_service $RKWIFIBT_DIR/S36wifibt-init.sh
